        }
      ],
      "networks": {
        "Immich": {}
      },
      "routes": null,
      "restart": "always",
      "devices": null,
      "expose": [],
      "command": "redis-server",
      "entrypoint": "docker-entrypoint.sh",
      "runtime": "runc",
      "working_dir": "/data",
      "network_mode": "Immich",
      "healthcheck": {
        "test": null,
        "interval": 0,
        "timeout": 0,
        "retries": 0,
        "start_period": 0
      }
    }
  }
}
