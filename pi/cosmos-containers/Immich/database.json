{
  "services": {
    "Immich-database": {
      "container_name": "Immich-database",
      "image": "ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0@sha256:bcf63357191b76a916ae5eb93464d65c07511da41e3bf7a8416db519b40b1c23",
      "environment": [
        "POSTGRES_PASSWORD=<your_immich_db_password>",
        "POSTGRES_USER=postgres",
        "POSTGRES_DB=immich",
        "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/lib/postgresql/14/bin",
        "GOSU_VERSION=1.16",
        "LANG=en_US.utf8",
        "PG_MAJOR=14",
        "PG_VERSION=14.10-1.pgdg120+1",
        "PGDATA=/var/lib/postgresql/data",
        "DB_STORAGE_TYPE=SSD"
      ],
      "labels": {
        "cosmos-auto-update": "true",
        "cosmos-force-network-mode": "Immich",
        "cosmos-force-network-secured": "true",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Immich/icon.png",
        "cosmos-persistent-env": "POSTGRES_PASSWORD, POSTGRES_USER, POSTGRES_DB",
        "cosmos-stack": "Immich",
        "cosmos-stack-main": "Immich",
        "org.opencontainers.image.created": "2025-10-07T12:08:54.320Z",
        "org.opencontainers.image.description": "Base images for Immich containers",
        "org.opencontainers.image.licenses": "AGPL-3.0",
        "org.opencontainers.image.revision": "c5095615488fa07469b5df48a3c3e5cebeed7296",
        "org.opencontainers.image.source": "https://github.com/immich-app/base-images",
        "org.opencontainers.image.title": "base-images",
        "org.opencontainers.image.url": "https://github.com/immich-app/base-images",
        "org.opencontainers.image.version": "14-vectorchord0.4.3-pgvector0.8.1-pgvectors0.2.0"
      },
      "ports": [],
      "volumes": [
        {
          "Type": "volume",
          "Source": "Immich-pgdata",
          "Target": "/var/lib/postgresql/data"
        }
      ],
      "networks": {
        "Immich": {}
      },
      "routes": null,
      "restart": "always",
      "devices": null,
      "expose": [],
      "command": "postgres -c shared_preload_libraries=vchord.so,vectors.so -c search_path=\"$user\",public,vectors",
      "entrypoint": "docker-entrypoint.sh",
      "runtime": "runc",
      "user": "postgres",
      "network_mode": "Immich",
      "stop_signal": "SIGINT",
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "/usr/local/bin/healthcheck.sh"
        ],
        "interval": 300,
        "timeout": 0,
        "retries": 0,
        "start_period": 300
      }
    }
  }
}
