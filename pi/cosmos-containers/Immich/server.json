{
  "services": {
    "Immich": {
      "container_name": "Immich",
      "image": "ghcr.io/immich-app/immich-server:release",
      "environment": [
        "UPLOAD_LOCATION=/usr/src/app/upload",
        "TYPESENSE_API_KEY=<your_typesense_api_key>",
        "DB_PASSWORD=<your_immich_db_password>",
        "DB_HOSTNAME=Immich-database",
        "DB_USERNAME=postgres",
        "DB_DATABASE_NAME=immich",
        "REDIS_HOSTNAME=Immich-redis",
        "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/src/app/server/bin",
        "NODE_VERSION=22.18.0",
        "YARN_VERSION=1.22.22",
        "DEBIAN_RELEASE=trixie",
        "LD_LIBRARY_PATH=/usr/lib/jellyfin-ffmpeg/lib:/usr/lib/wsl/lib:",
        "NODE_ENV=production",
        "NVIDIA_DRIVER_CAPABILITIES=all",
        "NVIDIA_VISIBLE_DEVICES=all",
        "IMMICH_BUILD=17683392247",
        "IMMICH_BUILD_URL=https://github.com/immich-app/immich/actions/runs/17683392247",
        "IMMICH_BUILD_IMAGE=v1.142.0",
        "IMMICH_BUILD_IMAGE_URL=https://github.com/immich-app/immich/pkgs/container/immich-server",
        "IMMICH_REPOSITORY=immich-app/immich",
        "IMMICH_REPOSITORY_URL=https://github.com/immich-app/immich",
        "IMMICH_SOURCE_REF=v1.142.0",
        "IMMICH_SOURCE_COMMIT=4153848c68d416329deecf8b671e02bd754b4dd7",
        "IMMICH_SOURCE_URL=https://github.com/immich-app/immich/commit/4153848c68d416329deecf8b671e02bd754b4dd7"
      ],
      "labels": {
        "cosmos-auto-update": "true",
        "cosmos-force-network-mode": "Immich",
        "cosmos-force-network-secured": "true",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Immich/icon.png",
        "cosmos-persistent-env": "UPLOAD_LOCATION, TYPESENSE_API_KEY, DB_PASSWORD, DB_DATABASE_NAME",
        "cosmos-stack": "Immich",
        "cosmos-stack-main": "Immich",
        "org.opencontainers.image.created": "2025-09-12T18:52:50.389Z",
        "org.opencontainers.image.description": "High performance self-hosted photo and video management solution.",
        "org.opencontainers.image.licenses": "AGPL-3.0",
        "org.opencontainers.image.revision": "4153848c68d416329deecf8b671e02bd754b4dd7",
        "org.opencontainers.image.source": "https://github.com/immich-app/immich",
        "org.opencontainers.image.title": "immich",
        "org.opencontainers.image.url": "https://github.com/immich-app/immich",
        "org.opencontainers.image.version": "v1.142.0"
      },
      "ports": [],
      "volumes": [
        {
          "Type": "bind",
          "Source": "/etc/localtime",
          "Target": "/etc/localtime"
        },
        {
          "Type": "volume",
          "Source": "46e1ecd6a840ecff9106a20f5b01bff5bd92e100964eb66df0feb2d81727133a",
          "Target": "/data"
        },
        {
          "Type": "volume",
          "Source": "v_immich_upload",
          "Target": "/usr/src/app/upload"
        }
      ],
      "networks": {
        "Immich": {}
      },
      "routes": null,
      "restart": "always",
      "devices": null,
      "expose": [],
      "command": "start.sh",
      "entrypoint": "tini -- /bin/bash -c",
      "runtime": "runc",
      "working_dir": "/usr/src/app",
      "network_mode": "Immich",
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "immich-healthcheck"
        ],
        "interval": 0,
        "timeout": 0,
        "retries": 0,
        "start_period": 0
      }
    }
  }
}
